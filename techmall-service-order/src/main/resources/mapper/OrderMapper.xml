<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.techmall.order.mapper.OrderMapper">

    <resultMap id="OrderMap" type="com.techmall.order.entity.Order">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="userId" column="user_id"/>
        <result property="totalAmount" column="total_amount"/>
        <result property="status" column="status"/>
        <result property="receiverName" column="receiver_name"/>
        <result property="receiverPhone" column="receiver_phone"/>
        <result property="receiverAddr" column="receiver_addr"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.techmall.order.entity.Order"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO t_order (order_no, user_id, total_amount, status,
                             receiver_name, receiver_phone, receiver_addr,
                             created_at, updated_at)
        VALUES (#{orderNo}, #{userId}, #{totalAmount}, #{status},
                #{receiverName}, #{receiverPhone}, #{receiverAddr},
                NOW(), NOW())
    </insert>

    <select id="selectById" resultMap="OrderMap">
        SELECT * FROM t_order WHERE id = #{id}
    </select>

    <select id="selectByUserId" resultMap="OrderMap">
        SELECT * FROM t_order WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="selectByMerchantId" resultMap="OrderMap">
        SELECT DISTINCT o.* FROM t_order o
        INNER JOIN t_order_item oi ON o.id = oi.order_id
        WHERE oi.merchant_id = #{merchantId}
        ORDER BY o.created_at DESC
    </select>

    <select id="selectAll" resultMap="OrderMap">
        SELECT * FROM t_order
        <where>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

    <update id="updateStatus">
        UPDATE t_order SET status = #{status}, updated_at = NOW()
        WHERE id = #{id}
    </update>

</mapper>
